# NextAuth
NEXTAUTH_SECRET=your-random-secret-here   # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth App
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Single admin user
ADMIN_EMAIL=your@email.com

# GCP / Firebase Admin SDK service account
GCP_PROJECT_ID=your-gcp-project-id
GCP_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GCP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Firestore (leave blank to use default database)
FIRESTORE_DATABASE_ID=

# GCP Cloud Storage
GCS_BUCKET_NAME=your-bucket-name
GCS_PUBLIC_URL_BASE=https://storage.googleapis.com/your-bucket-name
